# Copy to .env (repo root for docker-compose, backend/.env for local dev)

# --- Database ---
# docker-compose default (leave unset locally to use SQLite):
# DATABASE_URL=postgresql+psycopg2://automom:automom@localhost:5432/automom
POSTGRES_PASSWORD=automom

# --- Auth ---
JWT_SECRET_KEY=generate-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI provider ---
# auto = OpenAI if key set, else Groq, else Gemini, else offline mock extractor
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Groq: OpenAI-compatible, fast, generous free tier — get a key at console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_MAX_RETRIES=3

# PDF backend: auto (weasyprint then chromium) | weasyprint | chromium
PDF_ENGINE=auto

# --- App ---
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_TRANSCRIPT_CHARS=60000
RATE_LIMIT_GENERATE=10/minute
